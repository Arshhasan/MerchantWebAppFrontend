{
  "name": "functions",
  "description": "Cloud Functions for Order OTP System",
  "scripts": {
    "lint": "eslint .",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "@google-cloud/vision": "^5.3.5",
    "@sendgrid/mail": "^8.1.6",
    "dotenv": "^17.4.1",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.2",
    "pdfkit": "^0.15.2"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": 2018,
      "sourceType": "script"
    },
    "rules": {
      "no-undef": "off",
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "max-len": [
        "warn",
        {
          "code": 120
        }
      ],
      "require-jsdoc": "off",
      "valid-jsdoc": "off"
    }
  },
  "private": true
}
