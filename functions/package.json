{
  "name": "functions",
  "description": "Cloud Functions for Order OTP System",
  "scripts": {
    "lint": "eslint .",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.5.0"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": 2018,
      "sourceType": "script"
    },
    "rules": {
      "no-undef": "off",
      "no-unused-vars": ["warn", {"argsIgnorePattern": "^_"}],
      "max-len": ["warn", {"code": 120}],
      "require-jsdoc": "off",
      "valid-jsdoc": "off"
    }
  },
  "private": true
}
